# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values. Never commit secrets.
# ---------------------------------------------------------------------------

# Public site URL — used for canonical links, OG tags, sitemap, email links.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase (auth stubs only in this pass — set values when you wire login/signup)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# PostgreSQL connection string for Prisma (Supabase, Neon, or any Postgres).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/shifted_ai?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/shifted_ai?sslmode=require"

# Resend — used for transactional email (waitlist confirmation, contact).
RESEND_API_KEY="re_YOUR_KEY"
RESEND_FROM_EMAIL="ShiftED AI <hello@shifted.ai>"
RESEND_ADMIN_EMAIL="team@shifted.ai"

# Stripe — placeholder for future billing integration.
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Upstash Redis for rate limiting (optional — code falls back to in-memory).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
